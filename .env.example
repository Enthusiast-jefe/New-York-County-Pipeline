# =========================================================================================
# .env.example — New York County Pipeline Blueprint
# =========================================================================================
# INSTRUCTIONS: Copy this file to a new file named exactly ".env" in the same directory.
# Fill in your real, private values in the ".env" file.
# NEVER commit your actual ".env" file to GitHub.
# =========================================================================================

# ── Airflow Core ─────────────────────────────────────────────────────────────────────────

# Generate a 32-byte key using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY="your_fernet_key_here"

# Use LocalExecutor for parallel task execution on a single host node
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# Set to False to prevent default tutorial DAGs from cluttering your dashboard
AIRFLOW__CORE__LOAD_EXAMPLES=False

# Generate a secure web session hex string using: python -c "import secrets; print(secrets.token_hex(16))"
AIRFLOW__WEBSERVER__SECRET_KEY="your_webserver_secret_key_here"


# ── PostgreSQL Metadata Database ─────────────────────────────────────────────────────────

POSTGRES_USER=airflow
POSTGRES_PASSWORD=your_secure_db_password_here
POSTGRES_DB=airflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Connection string formatted as: postgresql+psycopg2://user:password@host:port/dbname
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:your_secure_db_password_here@postgres:5432/airflow


# ── API Private Keys ─────────────────────────────────────────────────────────────────────

# Request an official US Census API key at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY="your_census_api_key_here"

# Request a Bureau of Labor Statistics API key at: https://data.bls.gov/registrationEngine/
BLS_API_KEY="your_bls_api_key_here"


# ── API Public Endpoints (Safe to keep as-is) ────────────────────────────────────────────

# Local Area Unemployment Statistics (LAUS) — NY
LAUS_ENDPOINT=https://data.ny.gov/resource/5hyu-bdh8.json

# Quarterly Census of Employment and Wages (QCEW) — NY
QCEW_ENDPOINT=https://data.ny.gov/resource/shc7-xcbw.json

# Crime Data — NY
CRIME_ENDPOINT=https://data.ny.gov/resource/sh5y-5av7.json


# ── GitHub Configuration ─────────────────────────────────────────────────────────────────

GIT_USER_NAME=your_github_username
GIT_USER_EMAIL=your_email@example.com

# Create a Fine-grained PAT at GitHub -> Settings -> Developer Settings -> Personal Access Tokens
# Permissions required: Repository Access (Target Repo Only), Contents (Read & Write)
GITHUB_PAT="your_github_personal_access_token_here"
GITHUB_REPO_URL=https://github.com/your_username/your-repo-name.git


# ── Data Paths (Inside the Container) ────────────────────────────────────────────────────
# Standard target paths within the Linux container file system. Do not modify.

DATA_RAW_PATH=/opt/airflow/data/raw
DATA_INTERMEDIATE_PATH=/opt/airflow/data/intermediate
DATA_CURATED_PATH=/opt/airflow/data/curated
DATA_REFERENCE_PATH=/opt/airflow/data/reference


# ── Local File Sources (Bind Mount Mapping) ──────────────────────────────────────────────

# Path on your PHYSICAL host machine (e.g., /Users/username/Downloads/folder_name)
SOURCE_DIR=your_local_host_machine_data_directory_path

# Path inside the container where Docker maps the host folder
LOCAL_SOURCE_MOUNT=/opt/airflow/data/sources


# ── Pipeline Runtime Config ──────────────────────────────────────────────────────────────

# Size limit per pagination request loop to protect memory limits
INGEST_CHUNK_SIZE=10000

# Delay in seconds between network requests to prevent API rate-limit blocking
INGEST_REQUEST_DELAY=0.5

# Minimum baseline score (0-100) for fuzzy string matching on county entries
FIPS_FUZZY_THRESHOLD=90